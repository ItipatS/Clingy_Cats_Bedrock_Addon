{
  "format_version": "1.8.0",
  "minecraft:spawn_rules": {
    "description": {
      "identifier": "clingy_cats:siamese",
      "population_control": "cat"
    },
    "conditions": [
      {
        "minecraft:spawns_on_surface": {},
        "minecraft:spawns_above_block_filter": {
          "blocks": ["grass_block", "sand", "gravel", "dirt", "podzol", "coarse_dirt"],
          "distance": 10
        },
        "minecraft:brightness_filter": {
          "min": 7,
          "max": 15,
          "adjust_for_weather": false
        },
        "minecraft:difficulty_filter": {
          "min": "peaceful",
          "max": "hard"
        },
        "minecraft:weight": {
          "default": 8
        },
        "minecraft:herd": {
          "min_size": 1,
          "max_size": 2
        },
        "minecraft:biome_filter": {
          "any_of": [
            { "test": "has_biome_tag", "value": "village" },
            { "test": "has_biome_tag", "value": "desert" },
            { "test": "has_biome_tag", "value": "savanna" }
          ]
        }
      }
    ]
  }
}
