                    "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true },
                    "cause": "lava",
                    "damage_per_tick": 4
                }]
            },
            "minecraft:healable": {
                "items": [
                    { "item": "fish",   "heal_amount": 2 },
                    { "item": "salmon", "heal_amount": 2 }
                ]
            },
            "minecraft:despawn": { "despawn_from_distance": {} },
            "minecraft:attack": { "damage": 2 },
            "minecraft:ambient_sound_interval": {
                "event_name": "ambient",
                "range": 16,
                "value": 8
            },
            "minecraft:on_target_acquired": { "event": "clingy_cats:target_acquired", "target": "self" },
            "minecraft:on_target_escape":   { "event": "clingy_cats:calm_down",        "target": "self" },
            "minecraft:environment_sensor": {
                "triggers": [
                    { "filters": { "test": "weather_at_position", "value": "precipitation" }, "event": "clingy_cats:on_rain" },
                    { "filters": { "test": "weather_at_position", "value": "clear" },         "event": "clingy_cats:on_weather_clear" }
                ]
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    { "cause": "fall", "deals_damage": "no" },
                    {
                        "on_damage": {
                            "filters": { "test": "enum_property", "domain": "clingy_cats:personality", "subject": "self", "value": "confident" },
                            "event": "clingy_cats:on_hurt_confident", "target": "self"
                        },
                        "deals_damage": "yes"
                    },
                    {
                        "on_damage": {
                            "filters": { "test": "enum_property", "domain": "clingy_cats:personality", "subject": "self", "value": "calm" },
                            "event": "clingy_cats:on_hurt_calm", "target": "self"
                        },
                        "deals_damage": "yes"
                    },
                    {
                        "on_damage": {
                            "filters": { "all_of": [
                                { "test": "enum_property", "domain": "clingy_cats:personality", "subject": "self", "operator": "!=", "value": "confident" },
                                { "test": "enum_property", "domain": "clingy_cats:personality", "subject": "self", "operator": "!=", "value": "calm" }
                            ]},
                            "event": "clingy_cats:on_hurt", "target": "self"
                        },
                        "deals_damage": "yes"
                    },
                    {
                        "on_damage": { "filters": { "test": "is_riding", "subject": "self" } },
                        "deals_damage": "no"
                    }
                ]
            },
            "minecraft:behavior.float":  { "priority": 0 },
            "minecraft:behavior.panic": {
                "priority": 1,
                "speed_multiplier": 1.25,
                "damage_sources": ["campfire","fire","fire_tick","freezing","lightning","lava","magma","temperature","soul_campfire"],
                "ignore_mob_damage": true
            },
            "minecraft:behavior.stalk_and_pounce_on_target": {
                "priority": 5,
                "stalk_speed": 1.2,
                "max_stalk_dist": 12.0,
                "leap_height": 0.9,
                "leap_dist": 0.8,
                "pounce_max_dist": 5.0,
                "interest_time": 2.0,
                "stuck_time": 2.0,
                "strike_dist": 2.0
            },
            "minecraft:behavior.move_to_land": {
                "goal_radius": 0.5,
                "search_count": 80,
                "search_height": 1,
                "search_range": 30
            },
            "minecraft:behavior.random_look_around": { "priority": 11 },
            "minecraft:behavior.look_at_player":     { "priority": 11, "look_distance": 6.0, "probability": 0.02 },
            "minecraft:shareables": {
                "singular_pickup": true,
                "all_items": true,
                "all_items_max_amount": 1,
                "items": [
                    { "item": "minecraft:is_food", "max_amount": 1, "want_amount": 1, "surplus_amount": 1, "priority": 0 }
                ]
            },
            "minecraft:behavior.go_and_give_items_to_owner": {
                "priority": 4,
                "run_speed": 8,
                "throw_sound": "purreow"
            }
        },

        "events": {

            "minecraft:entity_spawned": {
                "sequence": [
                    { "randomize": [
                        { "weight": 3, "add": { "component_groups": ["clingy_cats:adult","clingy_cats:wild"] } },
                        { "weight": 1, "add": { "component_groups": ["clingy_cats:baby", "clingy_cats:wild"] } }
                    ]},
                    { "trigger": "clingy_cats:spawn" }
                ]
            },

            "clingy_cats:spawn": {
                "sequence": [
                    { "trigger": "clingy_cats:randomize_sound_variant" },
                    { "queue_command": { "command": "scriptevent clingycats:catspawn" } }
                ]
            },

            "clingy_cats:born": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:adult","clingy_cats:wild"] } },
                    { "add":    { "component_groups": ["clingy_cats:baby","clingy_cats:tamed"] } },
                    { "trigger": "clingy_cats:randomize_sound_variant" }
                ]
            },

            "clingy_cats:ageable_grow_up": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:baby"] } },
                    { "add":    { "component_groups": ["clingy_cats:adult"] } },
                    { "trigger": "clingy_cats:randomize_sound_variant" },
                    { "queue_command": { "command": "scriptevent clingycats:restore_identity" } }
                ]
            },

            "clingy_cats:on_tame": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:wild"] } },
                    { "add":    { "component_groups": ["clingy_cats:tamed"] } },
                    { "queue_command": { "command": "scriptevent clingycats:restore_identity" } }
                ]
            },

            "clingy_cats:become_pregnant": {
                "sequence": [
                    { "add": { "component_groups": ["clingy_cats:pregnant"] } },
                    { "queue_command": { "command": "scriptevent clingycats:conception" } }
                ]
            },

            "clingy_cats:give_birth": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:pregnant"] } },
                    { "queue_command": { "command": "scriptevent clingycats:givebirth" } }
                ]
            },

            "clingy_cats:randomize_sound_variant": {
                "randomize": [
                    { "weight": 1, "set_property": { "clingy_cats:sound_variant": "default" } },
                    { "weight": 1, "set_property": { "clingy_cats:sound_variant": "royal" } }
                ]
            },

            "clingy_cats:on_hurt": {
                "set_property": { "clingy_cats:emotion": "scared" }
            },

            "clingy_cats:on_hurt_calm": {
                "sequence": [
                    { "set_property": { "clingy_cats:emotion": "angry" } },
                    { "add": { "component_groups": ["clingy_cats:aggressive"] } }
                ]
            },

            "clingy_cats:target_acquired": {
                "set_property": { "clingy_cats:state": "hunting" }
            },

            "clingy_cats:calm_down": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:aggressive"] } },
                    { "set_property": { "clingy_cats:emotion": "happy" } },
                    { "set_property": { "clingy_cats:state": "idle" } }
                ]
            },

            "clingy_cats:on_idle":    { "set_property": { "clingy_cats:state": "idle" } },
            "clingy_cats:on_flee":    { "set_property": { "clingy_cats:state": "fleeing" } },
            "clingy_cats:on_purring": { "set_property": { "clingy_cats:state": "purring" } },

            "clingy_cats:on_sleeping": {
                "sequence": [
                    { "set_property": { "clingy_cats:state": "sleeping" } },
                    { "randomize": [
                        { "weight": 1, "set_property": { "clingy_cats:sub_state": 0 } },
                        { "weight": 1, "set_property": { "clingy_cats:sub_state": 1 } },
                        { "weight": 1, "set_property": { "clingy_cats:sub_state": 2 } }
                    ]},
                    { "remove": { "component_groups": ["clingy_cats:state_grooming"] } },
                    { "add":    { "component_groups": ["clingy_cats:state_sleeping"] } }
                ]
            },

            "clingy_cats:on_grooming": {
                "sequence": [
                    { "set_property": { "clingy_cats:state": "grooming" } },
                    { "randomize": [
                        { "weight": 1, "set_property": { "clingy_cats:sub_state": 0 } },
                        { "weight": 1, "set_property": { "clingy_cats:sub_state": 1 } }
                    ]},
                    { "remove": { "component_groups": ["clingy_cats:state_sleeping"] } },
                    { "add":    { "component_groups": ["clingy_cats:state_grooming"] } }
                ]
            },

            "clingy_cats:idle_tick": {
                    "filters": { "test": "is_sitting", "subject": "self", "value": true },
                    "randomize": [
                        { "weight": 1, "trigger": "clingy_cats:on_sleeping" },
                        { "weight": 1, "trigger": "clingy_cats:on_grooming" }
                    ]
            },

            "clingy_cats:on_rain": {
                "add": { "component_groups": ["clingy_cats:find_cover"] }
            },

            "clingy_cats:on_weather_clear": {
                "remove": { "component_groups": ["clingy_cats:find_cover"] }
            },

            "clingy_cats:behavior_tick": {
                
            },
            "clingy_cats:behavior_end": {

            },

            "clingy_cats:on_hurt_confident": {
                "sequence": [
                    { "set_property": { "clingy_cats:emotion": "angry" } },
                    { "add": { "component_groups": ["clingy_cats:aggressive"] } }
                ]
            },

            "clingy_cats:riding_states": {
                "randomize": [
                    { "weight": 3, "set_property": { "clingy_cats:state": "sitting" } },
                    { "weight": 2, "sequence": [
                        { "set_property": { "clingy_cats:state": "sleeping" } },
                        { "randomize": [
                            { "weight": 1, "set_property": { "clingy_cats:sub_state": 0 } },
                            { "weight": 1, "set_property": { "clingy_cats:sub_state": 1 } },
                            { "weight": 1, "set_property": { "clingy_cats:sub_state": 2 } }
                        ]}
                    ]},
                    { "weight": 2, "sequence": [
                        { "set_property": { "clingy_cats:state": "grooming" } },
                        { "randomize": [
                            { "weight": 1, "set_property": { "clingy_cats:sub_state": 0 } },
                            { "weight": 1, "set_property": { "clingy_cats:sub_state": 1 } }
                        ]}
                    ]},
                    { "weight": 1, "trigger": "clingy_cats:on_drop_off" }
                ]
            },

            "clingy_cats:on_drop_off": {
                "sequence": [
                    { "set_property": { "clingy_cats:state": "idle" } },
                    { "queue_command": { "command": "scriptevent clingycats:drop_off_cat" } }
                ]
            },

            "clingy_cats:add_can_mount": {
                "add": { "component_groups": ["clingy_cats:can_mount"] }
            },

            "clingy_cats:request_shoulder_mount": {
                "queue_command": { "command": "scriptevent clingycats:request_shoulder_mount" }
            },

            "clingy_cats:on_riding_player": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:can_mount"] } },
                    { "set_property": { "clingy_cats:state": "idle" } },
                    { "add": { "component_groups": ["clingy_cats:riding_tick"] } }
                ]
            },

            "clingy_cats:off_riding_player": {
                "sequence": [
                    { "remove": { "component_groups": ["clingy_cats:riding_tick"] } },
                    { "set_property": { "clingy_cats:state": "idle" } },
                    { "queue_command": { "command": "scriptevent clingycats:restore_identity" } }
                ]
            },

            "minecraft:spawn_from_village": {}
        }
    }
}