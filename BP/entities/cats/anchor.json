{
  "format_version": "1.21.10",
  "minecraft:entity": {
    "description": {
      "identifier": "clingy_cats:shoulder_anchor",
      "is_spawnable": false,
      "is_summonable": true,
      "properties": {
        "clingy_cats:anchor_state": {
          "type": "enum",
          "values": ["idle", "mounted"],
          "default": "idle",
          "client_sync": false
        }
      }
    },

    "component_groups": {

      "clingy_cats:seeking": {
        "minecraft:behavior.find_mount": {
          "priority": 1,
          "within_radius": 6,
          "mount_distance": 4,
          "start_delay": 0,
          "target_needed": false,
          "avoid_water": false
        }
      },

      "clingy_cats:not_riding_player": {
        "minecraft:entity_sensor": {
          "relative_range": false,
          "subsensors": [
            {
              "event": "clingy_cats:on_riding_player",
              "event_filters": {
                "test": "is_riding",
                "operator": "equals",
                "subject": "self",
                "value": true
              },
              "range": [2.0, 2.0]
            }
          ]
        }
      },

      "clingy_cats:riding_player": {
        "minecraft:entity_sensor": {
          "relative_range": false,
          "subsensors": [
            {
              "event": "clingy_cats:off_riding_player",
              "event_filters": {
                "test": "is_riding",
                "operator": "equals",
                "subject": "self",
                "value": false
              },
              "range": [2.0, 2.0]
            }
          ]
        }
      }

    },

    "components": {
      "minecraft:type_family": {
        "family": ["parrot_tame", "clingy_cats_anchor"]
      },
      "minecraft:movement.basic": { "max_turn": 30 },
      "minecraft:navigation.walk": {},
      "minecraft:collision_box": { "width": 0.01, "height": 0.01 },
      "minecraft:physics": {
        "has_gravity": false,
        "has_collision": false,
        "push_towards_closest_space": false
      },
      "minecraft:damage_sensor": {
        "triggers": [{ "cause": "all", "deals_damage": "no" }]
      },
      "minecraft:rideable": {
        "seat_count": 1,
        "family_types": ["clingy_cats", "parrot_tame"],
        "pull_in_entities": false,
        "seats": { "position": [0.0, 0.0, 0.0] }
      },
      "minecraft:persistent": {}
    },

    "events": {

      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["clingy_cats:seeking", "clingy_cats:not_riding_player"]
        }
      },

      "clingy_cats:on_riding_player": {
        "remove": {
          "component_groups": ["clingy_cats:seeking", "clingy_cats:not_riding_player"]
        },
        "add": {
          "component_groups": ["clingy_cats:riding_player"]
        }
      },

      "clingy_cats:off_riding_player": {
        "remove": {
          "component_groups": ["clingy_cats:riding_player"]
        },
        "add": {
          "component_groups": ["clingy_cats:not_riding_player"]
        },
        "queue_command": {
          "command": "scriptevent clingycats:anchor_detached"
        }
      }

    }
  }
}